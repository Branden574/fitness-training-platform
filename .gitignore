# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# superpowers brainstorm visual companion (local-only mockups)
.superpowers/

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# design handoff (unzipped reference, not part of build)
/design-handoff
Martinez Fitness-handoff.zip
v4-health-check.log

# Capacitor — keep project scaffolding committed, ignore build artifacts
/ios/App/Pods
/ios/App/build
/ios/DerivedData
/ios/capacitor-cordova-ios-plugins
/android/build
/android/app/build
/android/.gradle
/android/local.properties
/android/capacitor-cordova-android-plugins
