// OPTIMIZED PRISMA SCHEMA FOR HIGH PERFORMANCE
// Add these indexes to your existing schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"  // Changed from SQLite for better performance
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique @index  // ✅ Already unique, added index for faster lookups
  emailVerified DateTime?
  password      String?
  passwordChangeRequired Boolean @default(false)
  image         String?
  role          Role      @default(CLIENT) @index  // ✅ Critical for role-based queries
  createdAt     DateTime  @default(now()) @index   // ✅ For sorting and filtering
  updatedAt     DateTime  @updatedAt

  // Performance-critical indexes
  trainerId      String?   @index  // ✅ Critical for trainer-client relationship queries
  
  // ... rest of your existing relations
  accounts Account[]
  sessions Session[]
  clientProfile  ClientProfile?
  workoutSessions WorkoutSession[]
  progressEntries ProgressEntry[]
  mealPlans      MealPlan[]
  foodEntries    FoodEntry[]
  sentMessages   Message[] @relation("MessageSender")
  receivedMessages Message[] @relation("MessageReceiver")
  notifications  Notification[]
  sentInvitations Invitation[] @relation("InvitationInviter")
  clientAppointments Appointment[] @relation("ClientAppointments")
  trainerAppointments Appointment[] @relation("TrainerAppointments")
  trainer        Trainer?
  clients        User[]        @relation("TrainerClients")
  assignedTrainer User?        @relation("TrainerClients", fields: [trainerId], references: [id])
  createdWorkouts Workout[]
  createdMealPlans MealPlan[] @relation("TrainerMealPlans")
  workoutProgress WorkoutProgress[]

  // Composite indexes for common query patterns
  @@index([role, trainerId])  // ✅ For "get all clients for trainer" queries
  @@index([email, role])      // ✅ For authentication + role checks
}

model FoodEntry {
  id          String   @id @default(cuid())
  userId      String   @index      // ✅ Critical for user-specific queries
  foodName    String
  quantity    Float
  unit        String   @default("grams")
  calories    Int
  protein     Float    @default(0)
  carbs       Float    @default(0)
  fat         Float    @default(0)
  mealType    MealType @default(SNACK) @index  // ✅ For meal filtering
  date        DateTime @index      // ✅ Critical for date-based queries
  notes       String?
  createdAt   DateTime @default(now()) @index
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Composite indexes for common queries
  @@index([userId, date])        // ✅ For "user's food entries on date" 
  @@index([userId, mealType])    // ✅ For "user's entries by meal type"
  @@index([date, mealType])      // ✅ For daily meal analysis
}

model ProgressEntry {
  id         String   @id @default(cuid())
  userId     String   @index      // ✅ Critical for user queries
  date       DateTime @index      // ✅ Critical for timeline queries
  weight     Float?
  bodyFat    Float?
  muscleMass Float?
  mood       Int?     // 1-10 scale
  energy     Int?     // 1-10 scale
  sleep      Float?   // hours
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Composite indexes
  @@index([userId, date])        // ✅ For user progress timeline
  @@unique([userId, date])       // ✅ One entry per user per day
}

model Appointment {
  id           String            @id @default(cuid())
  clientId     String            @index  // ✅ For client queries
  trainerId    String            @index  // ✅ For trainer queries
  startTime    DateTime          @index  // ✅ For chronological queries
  endTime      DateTime
  status       AppointmentStatus @default(PENDING) @index  // ✅ For status filtering
  type         AppointmentType   @default(CONSULTATION) @index
  notes        String?
  cancelReason String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  client  User @relation("ClientAppointments", fields: [clientId], references: [id])
  trainer User @relation("TrainerAppointments", fields: [trainerId], references: [id])

  // Composite indexes for common queries
  @@index([trainerId, startTime])    // ✅ Trainer's schedule
  @@index([clientId, startTime])     // ✅ Client's appointments
  @@index([status, startTime])       // ✅ Appointments by status and time
}

model WorkoutSession {
  id           String    @id @default(cuid())
  workoutId    String    @index  // ✅ For workout queries
  userId       String    @index  // ✅ For user queries
  startTime    DateTime? @index  // ✅ For chronological queries
  endTime      DateTime?
  completed    Boolean   @default(false) @index  // ✅ For filtering completed sessions
  notes        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  workout         Workout           @relation(fields: [workoutId], references: [id])
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  workoutProgress WorkoutProgress[]

  // Composite indexes
  @@index([userId, completed])       // ✅ User's completed workouts
  @@index([userId, startTime])       // ✅ User's workout history
}

model Notification {
  id        String            @id @default(cuid())
  userId    String            @index  // ✅ Critical for user notifications
  title     String
  message   String
  type      NotificationType  @default(GENERAL) @index  // ✅ For type filtering
  read      Boolean           @default(false) @index    // ✅ For unread filtering
  createdAt DateTime          @default(now()) @index     // ✅ For chronological sorting
  updatedAt DateTime          @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Composite indexes
  @@index([userId, read])            // ✅ User's unread notifications
  @@index([userId, createdAt])       // ✅ User's recent notifications
}

model MealPlan {
  id                   String   @id @default(cuid())
  name                 String
  description          String?
  dailyCalorieTarget   Int      @default(2000)
  dailyProteinTarget   Int      @default(150)
  dailyCarbTarget      Int      @default(200)  
  dailyFatTarget       Int      @default(70)
  startDate            DateTime @index  // ✅ For date filtering
  endDate              DateTime @index  // ✅ For active plan queries
  userId               String   @index  // ✅ For user queries
  trainerId            String   @index  // ✅ For trainer queries
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user    User @relation(fields: [userId], references: [id], onDelete: Cascade)
  trainer User @relation("TrainerMealPlans", fields: [trainerId], references: [id])
  meals   Meal[]

  // Composite indexes
  @@index([userId, startDate, endDate])  // ✅ Active plans for user
  @@index([trainerId, createdAt])        // ✅ Trainer's created plans
}

