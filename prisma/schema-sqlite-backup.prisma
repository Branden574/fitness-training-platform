// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  password      String?   // For credentials provider
  passwordChangeRequired Boolean @default(false) // Force password change on first login
  image         String?
  role          Role      @default(CLIENT)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]

  // Client specific fields
  trainerId      String?
  clientProfile  ClientProfile?
  workoutSessions WorkoutSession[]
  progressEntries ProgressEntry[]
  mealPlans      MealPlan[]
  foodEntries    FoodEntry[]
  sentMessages   Message[] @relation("MessageSender")
  receivedMessages Message[] @relation("MessageReceiver")
  notifications  Notification[]
  sentInvitations Invitation[] @relation("InvitationInviter")
  
  // Appointment relationships
  clientAppointments Appointment[] @relation("ClientAppointments")
  trainerAppointments Appointment[] @relation("TrainerAppointments")

  // Trainer specific fields
  trainer        Trainer?
  clients        User[]        @relation("TrainerClients")
  assignedTrainer User?        @relation("TrainerClients", fields: [trainerId], references: [id])
  createdWorkouts Workout[]
  createdMealPlans MealPlan[] @relation("TrainerMealPlans")
  workoutProgress WorkoutProgress[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Trainer {
  id              String   @id @default(cuid())
  userId          String   @unique
  bio             String?
  specializations String?  // JSON string
  experience      Int      @default(0)
  certifications  String?  // JSON string
  hourlyRate      Float?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ClientProfile {
  id                String     @id @default(cuid())
  userId            String     @unique
  age               Int?
  height            Float?     // in cm
  weight            Float?     // in kg
  fitnessGoals      String?    // JSON string
  fitnessLevel      FitnessLevel @default(BEGINNER)
  medicalConditions String?    // JSON string
  preferences       String?    // JSON string
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Exercise {
  id           String     @id @default(cuid())
  name         String
  description  String?
  instructions String?    // JSON string
  muscleGroups String?    // JSON string
  equipment    String?    // JSON string
  difficulty   Difficulty @default(BEGINNER)
  imageUrl     String?
  videoUrl     String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  workoutExercises WorkoutExercise[]
  workoutProgress  WorkoutProgress[]
}

model Workout {
  id               String            @id @default(cuid())
  title            String
  description      String?
  duration         Int               // in minutes
  difficulty       Difficulty        @default(BEGINNER)
  type             WorkoutType       @default(STRENGTH)
  exercises        WorkoutExercise[]
  createdBy        String
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  creator  User             @relation(fields: [createdBy], references: [id])
  sessions WorkoutSession[]
}

model WorkoutExercise {
  id        String @id @default(cuid())
  workoutId String
  exerciseId String
  sets      Int
  reps      Int?
  duration  Int?    // in seconds
  weight    Float?
  restTime  Int?    // in seconds
  notes     String?
  order     Int

  workout  Workout  @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  exercise Exercise @relation(fields: [exerciseId], references: [id])

  @@unique([workoutId, exerciseId])
}

model WorkoutSession {
  id              String   @id @default(cuid())
  workoutId       String
  userId          String
  startTime       DateTime
  endTime         DateTime?
  completed       Boolean  @default(false)
  notes           String?
  rating          Int?     // 1-5 stars
  caloriesBurned  Int?
  createdAt       DateTime @default(now())

  workout          Workout            @relation(fields: [workoutId], references: [id])
  user             User               @relation(fields: [userId], references: [id])
  exerciseProgress ExerciseProgress[]
  workoutProgress  WorkoutProgress[]

  @@unique([workoutId, userId])
}

model ExerciseProgress {
  id               String @id @default(cuid())
  sessionId        String
  exerciseId       String
  setsCompleted    Int
  repsPerSet       String? // JSON string
  weightsUsed      String? // JSON string
  restTimes        String? // JSON string
  notes            String?

  session WorkoutSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model WorkoutProgress {
  id               String   @id @default(cuid())
  userId           String
  exerciseId       String
  workoutSessionId String
  weight           Float?
  sets             Int?
  reps             Int?
  notes            String?
  date             DateTime @default(now())
  createdAt        DateTime @default(now())

  user             User             @relation(fields: [userId], references: [id])
  exercise         Exercise         @relation(fields: [exerciseId], references: [id])
  workoutSession   WorkoutSession   @relation(fields: [workoutSessionId], references: [id])
}

model Food {
  id               String @id @default(cuid())
  name             String
  brand            String?
  caloriesPerServing Int
  protein          Float
  carbs            Float
  fat              Float
  fiber            Float?
  sugar            Float?
  sodium           Float?
  servingSize      String
  servingUnit      String
  createdAt        DateTime @default(now())

  mealItems MealItem[]
  foodEntries FoodEntry[]
}

model FoodEntry {
  id        String    @id @default(cuid())
  userId    String
  foodName  String
  quantity  Float
  unit      String
  calories  Int
  protein   Float
  carbs     Float
  fat       Float
  mealType  MealType
  date      DateTime
  notes     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id])
  food Food? @relation(fields: [foodId], references: [id])
  foodId String?
}

model Meal {
  id         String     @id @default(cuid())
  name       String
  type       MealType
  items      MealItem[]
  mealPlanId String

  mealPlan MealPlan @relation(fields: [mealPlanId], references: [id], onDelete: Cascade)
}

model MealItem {
  id       String @id @default(cuid())
  mealId   String
  foodId   String
  quantity Float
  notes    String?

  meal Meal @relation(fields: [mealId], references: [id], onDelete: Cascade)
  food Food @relation(fields: [foodId], references: [id])
}

model MealPlan {
  id                  String   @id @default(cuid())
  name                String
  description         String?
  userId              String
  trainerId           String
  startDate           DateTime
  endDate             DateTime
  dailyCalorieTarget  Int
  dailyProteinTarget  Float
  dailyCarbTarget     Float
  dailyFatTarget      Float
  meals               Meal[]
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user    User @relation(fields: [userId], references: [id])
  trainer User @relation("TrainerMealPlans", fields: [trainerId], references: [id])
}

model ProgressEntry {
  id           String    @id @default(cuid())
  userId       String
  date         DateTime
  weight       Float?
  bodyFat      Float?
  muscleMass   Float?
  measurements Json?     // Store chest, waist, hips, etc.
  photos       String?   // JSON string
  notes        String?
  mood         Int?      // 1-10 scale
  energy       Int?      // 1-10 scale
  sleep        Float?    // hours
  createdAt    DateTime  @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, date])
}

model Message {
  id         String      @id @default(cuid())
  senderId   String
  receiverId String
  content    String
  type       MessageType @default(TEXT)
  fileUrl    String?
  read       Boolean     @default(false)
  createdAt  DateTime    @default(now())

  sender   User @relation("MessageSender", fields: [senderId], references: [id])
  receiver User @relation("MessageReceiver", fields: [receiverId], references: [id])
}

model Notification {
  id           String           @id @default(cuid())
  userId       String
  title        String
  message      String
  type         NotificationType
  read         Boolean          @default(false)
  actionUrl    String?
  appointmentId String?
  createdAt    DateTime         @default(now())

  user User @relation(fields: [userId], references: [id])
}

model ContactSubmission {
  id              String   @id @default(cuid())
  name            String
  email           String
  phone           String?
  message         String
  // Enhanced fitness assessment fields
  age             String?
  fitnessLevel    String?
  fitnessGoals    String?
  currentActivity String?
  injuries        String?
  availability    String?
  status          ContactStatus @default(NEW)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Invitation {
  id          String          @id @default(cuid())
  email       String
  phone       String?
  code        String          @unique
  invitedBy   String
  status      InvitationStatus @default(PENDING)
  expiresAt   DateTime
  acceptedAt  DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  inviter User @relation("InvitationInviter", fields: [invitedBy], references: [id])

  @@unique([email, status])
}

model Appointment {
  id            String           @id @default(cuid())
  clientId      String
  trainerId     String
  title         String
  description   String?
  type          AppointmentType
  status        AppointmentStatus @default(PENDING)
  startTime     DateTime
  endTime       DateTime
  duration      Int              // in minutes
  location      String?
  notes         String?
  cancelReason  String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  
  client  User @relation("ClientAppointments", fields: [clientId], references: [id])
  trainer User @relation("TrainerAppointments", fields: [trainerId], references: [id])
}

enum AppointmentType {
  TRAINING_SESSION
  CHECK_IN
  NUTRITION_CONSULTATION
  ASSESSMENT
  FOLLOW_UP
}

enum AppointmentStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum Role {
  CLIENT
  TRAINER
  ADMIN
}

enum FitnessLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum Difficulty {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum WorkoutType {
  STRENGTH
  CARDIO
  FLEXIBILITY
  MIXED
}

enum MealType {
  BREAKFAST
  LUNCH
  DINNER
  SNACK
}

enum MessageType {
  TEXT
  IMAGE
  FILE
}

enum NotificationType {
  WORKOUT_ASSIGNED
  MEAL_PLAN_ASSIGNED
  MEAL_PLAN_ENDED
  MESSAGE_RECEIVED
  PROGRESS_REMINDER
  APPOINTMENT_CANCELLED
  APPOINTMENT_RESCHEDULED
  APPOINTMENT_READ
  GENERAL
}

enum ContactStatus {
  NEW
  IN_PROGRESS
  CONTACTED
  INVITED
  COMPLETED
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}