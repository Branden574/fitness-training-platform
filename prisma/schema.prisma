// ─── ECOMMERCE MODELS ───

// Shop models (Product, Order, etc.) removed — feature retired.
// Subscription (below) is kept because it's a separate feature for
// trainer/platform billing and uses its own webhook + admin billing page.

// ══════════════════════════════════════════════════════════════════
// V4 Phase 8 additions — Program builder, coach notes, feature flags,
// Stripe subscriptions. All additive; no existing model altered in
// a breaking way.
// ══════════════════════════════════════════════════════════════════

model Program {
  id          String              @id @default(cuid())
  name        String
  description String?
  goal        String?
  durationWks Int
  isTemplate  Boolean             @default(false)
  archived    Boolean             @default(false)
  createdById String
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  creator     User                @relation("ProgramCreator", fields: [createdById], references: [id])
  weeks       ProgramWeek[]
  assignments ProgramAssignment[]
  mealPlans   ProgramMealPlan[]

  @@index([createdById])
  @@index([isTemplate])
  @@index([archived])
  @@map("programs")
}

model ProgramWeek {
  id         String       @id @default(cuid())
  programId  String
  weekNumber Int
  name       String?
  notes      String?
  program    Program      @relation(fields: [programId], references: [id], onDelete: Cascade)
  days       ProgramDay[]

  @@unique([programId, weekNumber])
  @@index([programId])
  @@map("program_weeks")
}

model ProgramDay {
  id            String               @id @default(cuid())
  programWeekId String
  dayOfWeek     DayOfWeek
  sessionType   String
  notes         String?
  order         Int                  @default(0)
  programWeek   ProgramWeek          @relation(fields: [programWeekId], references: [id], onDelete: Cascade)
  exercises     ProgramDayExercise[]

  @@index([programWeekId])
  @@map("program_days")
}

model ProgramDayExercise {
  id           String     @id @default(cuid())
  programDayId String
  exerciseId   String
  order        Int
  sets         Int
  repsScheme   String
  targetWeight String?
  restSeconds  Int?
  tempo        String?
  notes        String?
  programDay   ProgramDay @relation(fields: [programDayId], references: [id], onDelete: Cascade)
  exercise     Exercise   @relation(fields: [exerciseId], references: [id])

  @@index([programDayId])
  @@index([exerciseId])
  @@map("program_day_exercises")
}

model ProgramAssignment {
  id           String           @id @default(cuid())
  programId    String
  clientId     String
  assignedById String
  startDate    DateTime
  currentWeek  Int              @default(1)
  status       AssignmentStatus @default(ACTIVE)
  notes        String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  program      Program          @relation(fields: [programId], references: [id])
  client       User             @relation("ClientAssignments", fields: [clientId], references: [id])
  assigner     User             @relation("TrainerAssignments", fields: [assignedById], references: [id])

  @@index([clientId])
  @@index([assignedById])
  @@index([programId])
  @@index([status])
  @@map("program_assignments")
}

// Meal plan template attached to a Program. A Program can have zero, one, or
// many plans. Each plan covers a week range (startWeek/endWeek, 1-indexed,
// inclusive). If endWeek is null the plan runs to the end of the program. A
// program with one plan and no range set = applies to the whole program.
// On ProgramAssignment creation, each ProgramMealPlan is cloned into a real
// per-client MealPlan row with concrete start/end dates derived from the
// assignment's startDate.
model ProgramMealPlan {
  id                 String        @id @default(cuid())
  programId          String
  name               String
  description        String?
  startWeek          Int           @default(1)
  endWeek            Int?
  dailyCalorieTarget Int
  dailyProteinTarget Float
  dailyCarbTarget    Float
  dailyFatTarget     Float
  order              Int           @default(0)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  program            Program       @relation(fields: [programId], references: [id], onDelete: Cascade)
  meals              ProgramMeal[]
  clones             MealPlan[]

  @@index([programId])
  @@map("program_meal_plans")
}

model ProgramMeal {
  id                String            @id @default(cuid())
  programMealPlanId String
  name              String
  type              MealType
  order             Int               @default(0)
  notes             String?
  programMealPlan   ProgramMealPlan   @relation(fields: [programMealPlanId], references: [id], onDelete: Cascade)
  items             ProgramMealItem[]

  @@index([programMealPlanId])
  @@map("program_meals")
}

model ProgramMealItem {
  id            String      @id @default(cuid())
  programMealId String
  foodId        String
  quantity      Float
  order         Int         @default(0)
  notes         String?
  programMeal   ProgramMeal @relation(fields: [programMealId], references: [id], onDelete: Cascade)
  food          Food        @relation(fields: [foodId], references: [id])

  @@index([programMealId])
  @@index([foodId])
  @@map("program_meal_items")
}

enum DayOfWeek {
  MON
  TUE
  WED
  THU
  FRI
  SAT
  SUN
}

enum AssignmentStatus {
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED
}

model CoachNote {
  id        String      @id @default(cuid())
  trainerId String
  clientId  String
  body      String
  context   NoteContext @default(GENERAL)
  contextId String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  trainer   User        @relation("CoachNotesTrainer", fields: [trainerId], references: [id])
  client    User        @relation("CoachNotesClient", fields: [clientId], references: [id])

  @@index([trainerId])
  @@index([clientId])
  @@index([createdAt])
  @@map("coach_notes")
}

enum NoteContext {
  GENERAL
  TRAINING
  NUTRITION
  PROGRESS
}

model FeatureFlag {
  key         String   @id
  enabled     Boolean  @default(false)
  description String?
  updatedAt   DateTime @updatedAt
  updatedBy   String?

  @@map("feature_flags")
}

model Subscription {
  id                   String    @id @default(cuid())
  userId               String    @unique
  stripeCustomerId     String?   @unique
  stripeSubscriptionId String?   @unique
  stripePriceId        String?
  plan                 String?
  status               String?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean   @default(false)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  user                 User      @relation(fields: [userId], references: [id])

  @@index([stripeCustomerId])
  @@index([status])
  @@map("subscriptions")
}

