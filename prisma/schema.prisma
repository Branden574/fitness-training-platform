generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model User {
  id                      String                  @id @default(cuid())
  name                    String?
  email                   String                  @unique
  emailVerified           DateTime?
  password                String?
  passwordChangeRequired  Boolean                 @default(false)
  image                   String?
  role                    Role                    @default(CLIENT)
  isActive                Boolean                 @default(true)
  lastLogin               DateTime?
  loginCount              Int                     @default(0)
  adminNotes              String?
  createdAt               DateTime                @default(now())
  updatedAt               DateTime                @updatedAt
  trainerId               String?
  accounts                Account[]
  clientAppointments      Appointment[]           @relation("ClientAppointments")
  trainerAppointments     Appointment[]           @relation("TrainerAppointments")
  clientProfile           ClientProfile?
  foodEntries             FoodEntry[]
  favoriteFoods           FavoriteFood[]
  sentInvitations         Invitation[]            @relation("InvitationInviter")
  createdMealPlans        MealPlan[]              @relation("TrainerMealPlans")
  mealPlans               MealPlan[]
  receivedMessages        Message[]               @relation("MessageReceiver")
  sentMessages            Message[]               @relation("MessageSender")
  notifications           Notification[]
  weeklyDigests           WeeklyDigest[]          @relation("TrainerWeeklyDigest")
  pushSubscriptions       PushSubscription[]
  devicePushTokens        DevicePushToken[]
  notificationPreference  NotificationPreference?
  nutritionPlans          NutritionPlan[]
  progressEntries         ProgressEntry[]
  sessions                Session[]
  trainer                 Trainer?
  assignedTrainer         User?                   @relation("TrainerClients", fields: [trainerId], references: [id])
  clients                 User[]                  @relation("TrainerClients")
  workoutProgress         WorkoutProgress[]
  workoutSessions         WorkoutSession[]
  createdWorkouts         Workout[]
  createdPrograms         Program[]               @relation("ProgramCreator")
  clientAssignments       ProgramAssignment[]     @relation("ClientAssignments")
  assignedPrograms        ProgramAssignment[]     @relation("TrainerAssignments")
  coachNotesAsTrainer     CoachNote[]             @relation("CoachNotesTrainer")
  coachNotesAsClient      CoachNote[]             @relation("CoachNotesClient")
  subscription            Subscription?
  trainerApplications     ContactSubmission[]     @relation("TrainerApplications")
  trainerAgreement        TrainerAgreement?       @relation("UserAgreement")
  // NOTE: @unique on trainerSlug + trainerReferralCode is DEFERRED. Railway's
  // `prisma db push` refuses to add unique constraints without --accept-data-loss,
  // and we removed that flag after the earlier shop-drop. Collision avoidance is
  // handled in code by trainerIdentity.ts (retry loops + findFirst checks). A
  // dedicated migration will add the actual unique index later.
  trainerSlug             String?
  trainerReferralCode     String?
  trainerIsPublic         Boolean                 @default(false)
  trainerAcceptingClients Boolean                 @default(true)
  trainerClientStatus     TrainerClientStatus     @default(ACCEPTING)

  // IANA timezone name (e.g. "America/Los_Angeles"). Nullable — client can
  // leave unset; UI falls back to the browser's Intl.DateTimeFormat zone for
  // rendering. Trainer-facing log views use this to show "when did the
  // client actually eat this" in the client's local time, not the trainer's.
  timezone String?

  @@index([email])
  @@index([role])
  @@index([trainerId])
  @@index([isActive])
  @@index([lastLogin])
  @@index([createdAt])
  @@index([trainerSlug])
  @@index([trainerReferralCode])
  // Supports /api/trainers/search — narrows to the TRAINER+public subset
  // before the ILIKE name filter. name ILIKE '%q%' can't use a B-tree index
  // regardless (leading wildcard), so this composite is the real optimization.
  @@index([role, trainerIsPublic])
  @@map("users")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model AdminLog {
  id           String   @id @default(cuid())
  adminEmail   String
  action       String
  targetUserId String?
  targetEmail  String?
  details      Json?
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())

  @@index([adminEmail])
  @@index([action])
  @@index([targetUserId])
  @@index([createdAt])
  @@map("admin_logs")
}

model LoginEvent {
  id        String   @id @default(cuid())
  email     String
  userId    String?
  success   Boolean
  ipAddress String?
  userAgent String?
  reason    String? // "invalid_password", "account_disabled", "success", etc.
  createdAt DateTime @default(now())

  @@index([email])
  @@index([userId])
  @@index([success])
  @@index([createdAt])
  @@map("login_events")
}

model ApiRequestLog {
  id        String   @id @default(cuid())
  userId    String?
  userEmail String?
  method    String
  path      String
  status    Int
  ipAddress String?
  duration  Int? // ms
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([path])
  @@index([createdAt])
  @@map("api_request_logs")
}

model Trainer {
  id              String   @id @default(cuid())
  userId          String   @unique
  bio             String?
  specializations Json?
  experience      Int      @default(0)
  certifications  Json?
  hourlyRate      Float?
  photoUrl        String?
  location        String?
  instagramHandle String?
  priceTier       String?
  specialties     String[] @default([])
  acceptsInPerson Boolean  @default(false)
  acceptsOnline   Boolean  @default(false)
  // Public contact phone for the apply page FASTEST REPLY card — nullable so
  // the card hides for trainers who haven't configured one yet. Stored in the
  // raw format the trainer enters; normalized to digits in the sms: href.
  contactPhone    String?

  // Profile redesign v1 — editorial fields rendered by the new /trainers and
  // /t/[slug] screens. All nullable / defaulted so existing trainers render
  // with graceful fallbacks (empty sections hide, cover uses gradient tile).
  headline       String? //  tagline under the name, ~160 char
  coverImageUrl  String? //  320px header cover (falls back to gradient)
  clientsTrained Int? //     lifetime career count — marketing copy, not platform history
  quickFacts     Json? //    [{label, value}] — profile "Quick Facts" card
  pillars        Json? //    [{title, description, icon}] — "Approach" 4-card grid
  gallery        String[] @default([]) //  image URLs in display order
  services       Json? //    [{title, description, price, per, cta, featured}] — pricing cards
  tiktokHandle   String?
  youtubeHandle  String?

  // Phase 3 — platform subscription billing (Martinez/Fitness charges trainer).
  // Tier is an app-level concept; the corresponding Stripe price is resolved
  // via env at checkout time so prices can change without a migration.
  // monthlyPrice is a nullable admin override for foundation testers / custom
  // deals — when set, UI shows it; subscriptionStatus=free skips Stripe entirely.
  subscriptionTier     String? // 'FREE' | 'STARTER' | 'PRO' | 'CUSTOM'
  monthlyPrice         Float?
  subscriptionStatus   String? // 'free' | 'trialing' | 'active' | 'past_due' | 'canceled'
  stripeCustomerId     String?
  stripeSubscriptionId String?

  // Phase 3 — Stripe Connect (trainer accepts client payments via the platform).
  stripeConnectAccountId String?
  connectOnboarded       Boolean @default(false)
  connectChargesEnabled  Boolean @default(false)
  connectPayoutsEnabled  Boolean @default(false)

  // Phase 5 — per-trainer reply-to routing for contact-submission notifications.
  replyFromEmail String?
  replyFromName  String?

  profilePublishedAt DateTime?
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  user               User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  testimonials       TrainerTestimonial[]
  transformations    TrainerTransformation[]

  @@index([profilePublishedAt])
  @@map("trainers")
}

model ClientProfile {
  id                String       @id @default(cuid())
  userId            String       @unique
  age               Int?
  height            Float?
  weight            Float?
  fitnessGoals      Json?
  fitnessLevel      FitnessLevel @default(BEGINNER)
  medicalConditions Json?
  preferences       Json?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  user              User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("client_profiles")
}

model Exercise {
  id                  String               @id @default(cuid())
  name                String
  description         String?
  instructions        Json?
  muscleGroups        Json?
  equipment           Json?
  difficulty          Difficulty           @default(BEGINNER)
  imageUrl            String?
  videoUrl            String?
  // Ownership scope. `null` = shared stock library (seeded from
  // free-exercise-db), visible to every trainer and read-only except for
  // admins. Non-null = private to that user's exercise library —
  // only the creator (or an admin) sees / edits / deletes them. Existing
  // rows default to null on the migration, preserving the shared library.
  createdByUserId     String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  workoutExercises    WorkoutExercise[]
  workoutProgress     WorkoutProgress[]
  programDayExercises ProgramDayExercise[]

  // NOTE: @unique on `name` was removed — production has duplicate exercises
  // and `prisma db push` refuses to add the constraint without data loss.
  // Dedupe will happen via a dedicated admin task, then this can be restored.
  @@index([name])
  @@index([difficulty])
  @@index([createdByUserId])
  @@map("exercises")
}

model Workout {
  id          String            @id @default(cuid())
  title       String
  description String?
  duration    Int
  difficulty  Difficulty        @default(BEGINNER)
  type        WorkoutType       @default(STRENGTH)
  createdBy   String
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  exercises   WorkoutExercise[]
  sessions    WorkoutSession[]
  creator     User              @relation(fields: [createdBy], references: [id])

  @@index([createdBy])
  @@index([difficulty])
  @@index([type])
  @@map("workouts")
}

model WorkoutExercise {
  id         String   @id @default(cuid())
  workoutId  String
  exerciseId String
  sets       Int
  reps       Int?
  duration   Int?
  weight     Float?
  restTime   Int?
  notes      String?
  order      Int
  exercise   Exercise @relation(fields: [exerciseId], references: [id])
  workout    Workout  @relation(fields: [workoutId], references: [id], onDelete: Cascade)

  @@index([workoutId])
  @@index([exerciseId])
  @@map("workout_exercises")
}

model WorkoutSession {
  id               String             @id @default(cuid())
  workoutId        String
  userId           String
  startTime        DateTime
  endTime          DateTime?
  completed        Boolean            @default(false)
  notes            String?
  rating           Int?
  aiSummary        String?
  caloriesBurned   Int?
  createdAt        DateTime           @default(now())
  exerciseProgress ExerciseProgress[]
  workoutProgress  WorkoutProgress[]
  user             User               @relation(fields: [userId], references: [id])
  workout          Workout            @relation(fields: [workoutId], references: [id])

  @@index([userId, workoutId, startTime])
  @@index([userId, startTime])
  @@index([workoutId])
  @@map("workout_sessions")
}

model ExerciseProgress {
  id            String         @id @default(cuid())
  sessionId     String
  exerciseId    String
  setsCompleted Int
  repsPerSet    Json?
  weightsUsed   Json?
  restTimes     Json?
  notes         String?
  session       WorkoutSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("exercise_progress")
}

model WorkoutProgress {
  id               String         @id @default(cuid())
  userId           String
  exerciseId       String
  workoutSessionId String
  weight           Float?
  sets             Int?
  reps             Int?
  notes            String?
  date             DateTime       @default(now())
  createdAt        DateTime       @default(now())
  exercise         Exercise       @relation(fields: [exerciseId], references: [id])
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  workoutSession   WorkoutSession @relation(fields: [workoutSessionId], references: [id], onDelete: Cascade)

  @@index([userId, date])
  @@index([exerciseId])
  @@index([userId, exerciseId])
  @@map("workout_progress")
}

model Food {
  id                 String            @id @default(cuid())
  name               String
  brand              String?
  caloriesPerServing Int
  protein            Float
  carbs              Float
  fat                Float
  fiber              Float?
  sugar              Float?
  sodium             Float?
  servingSize        String
  servingUnit        String
  createdAt          DateTime          @default(now())
  foodEntries        FoodEntry[]
  mealItems          MealItem[]
  programMealItems   ProgramMealItem[]

  @@index([name])
  @@map("foods")
}

model CommunityFood {
  id          String   @id @default(cuid())
  barcode     String?  @unique
  name        String
  brand       String?
  calories    Float
  protein     Float
  carbs       Float
  fat         Float
  fiber       Float?
  sugar       Float?
  servingSize Float
  servingUnit String
  category    String?
  verified    Boolean  @default(false)
  addedBy     String
  useCount    Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([barcode])
  @@index([name])
  @@index([brand])
  @@index([useCount])
  @@map("community_foods")
}

model FoodEntry {
  id        String   @id @default(cuid())
  userId    String
  foodName  String
  quantity  Float
  unit      String
  calories  Float
  protein   Float
  carbs     Float
  fat       Float
  mealType  MealType
  date      DateTime
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  foodId    String?
  food      Food?    @relation(fields: [foodId], references: [id])
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
  @@index([date])
  @@index([mealType])
  @@map("food_entries")
}

model FavoriteFood {
  id          String   @id @default(cuid())
  userId      String
  foodName    String
  brand       String?
  calories    Float
  protein     Float
  carbs       Float
  fat         Float
  servingSize Float
  servingUnit String
  category    String?
  sourceId    String? // External ID (usda-xxx, off-xxx, local-xxx)
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, foodName, brand])
  @@index([userId])
  @@map("favorite_foods")
}

model Meal {
  id         String     @id @default(cuid())
  name       String
  type       MealType
  mealPlanId String
  items      MealItem[]
  mealPlan   MealPlan   @relation(fields: [mealPlanId], references: [id], onDelete: Cascade)

  @@map("meals")
}

model MealItem {
  id       String  @id @default(cuid())
  mealId   String
  foodId   String
  quantity Float
  notes    String?
  food     Food    @relation(fields: [foodId], references: [id])
  meal     Meal    @relation(fields: [mealId], references: [id], onDelete: Cascade)

  @@map("meal_items")
}

model MealPlan {
  id                 String           @id @default(cuid())
  name               String
  description        String?
  userId             String
  trainerId          String
  startDate          DateTime
  endDate            DateTime
  dailyCalorieTarget Int
  dailyProteinTarget Float
  dailyCarbTarget    Float
  dailyFatTarget     Float
  // Set when this MealPlan was cloned from a ProgramMealPlan template via
  // program assignment. Nullable for ad-hoc plans (existing per-client flow)
  // and so deleting a template via SetNull doesn't cascade-destroy client plans.
  // Used by the /republish endpoint to target exactly the clones that came
  // from a given template.
  sourceTemplateId   String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  trainer            User             @relation("TrainerMealPlans", fields: [trainerId], references: [id])
  user               User             @relation(fields: [userId], references: [id])
  sourceTemplate     ProgramMealPlan? @relation(fields: [sourceTemplateId], references: [id], onDelete: SetNull)
  meals              Meal[]

  @@index([userId])
  @@index([trainerId])
  @@index([sourceTemplateId])
  @@map("meal_plans")
}

model NutritionPlan {
  id            String   @id @default(cuid())
  userId        String
  dailyCalories Float
  proteinGrams  Float
  carbsGrams    Float
  fatGrams      Float
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("nutrition_plans")
}

model ProgressEntry {
  id           String   @id @default(cuid())
  userId       String
  date         DateTime
  weight       Float?
  bodyFat      Float?
  muscleMass   Float?
  measurements Json?
  photos       Json?
  notes        String?
  mood         Int?
  energy       Int?
  sleep        Float?
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date])
  @@map("progress_entries")
}

model Message {
  id         String      @id @default(cuid())
  senderId   String
  receiverId String
  content    String
  type       MessageType @default(TEXT)
  fileUrl    String?
  // Phase 2A (chat attachments). `attachment` is the canonical metadata blob
  // ({ url, mime, size, name, durationSec?, width?, height?, posterUrl? });
  // `fileUrl` mirrors `attachment.url` so pre-2A readers keep working.
  // Writers must populate both. Renderers branch on `type` (IMAGE/VIDEO/VOICE/FILE).
  attachment Json?
  read       Boolean     @default(false)
  createdAt  DateTime    @default(now())
  receiver   User        @relation("MessageReceiver", fields: [receiverId], references: [id], onDelete: Cascade)
  sender     User        @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([senderId])
  @@index([receiverId])
  @@index([createdAt])
  @@index([receiverId, read])
  @@map("messages")
}

model Notification {
  id            String           @id @default(cuid())
  userId        String
  title         String
  message       String
  type          NotificationType
  read          Boolean          @default(false)
  actionUrl     String?
  appointmentId String?
  // Additive evolution (Phase 3A). `body` mirrors `message` for callers that
  // use the spec's name; writers populate both so old readers keep working.
  // `readAt` is the authoritative "when was it read" source; `read` boolean
  // stays in sync for backwards compat with pre-3A queries that filter on it.
  // `metadata` carries arbitrary context (exerciseId, sessionId, etc.) without
  // polluting the top-level columns. Nullable on all three so db push works
  // without --accept-data-loss on Railway.
  body          String?
  readAt        DateTime?
  metadata      Json?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @default(now()) @updatedAt
  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([read])
  @@index([userId, readAt])
  @@index([userId, createdAt])
  @@map("notifications")
}

model WeeklyDigest {
  id            String   @id @default(cuid())
  trainerId     String
  weekStartIso  String
  payload       Json
  generatedAt   DateTime @default(now())
  trainer       User     @relation("TrainerWeeklyDigest", fields: [trainerId], references: [id], onDelete: Cascade)

  @@unique([trainerId, weekStartIso])
  @@index([trainerId, generatedAt])
  @@map("weekly_digests")
}

// Per-user web-push (VAPID) subscription. One row per registered browser
// profile — a single user can have many (laptop Chrome, phone Safari, etc.).
// Rows auto-delete when the endpoint returns 404/410 Gone during send.
model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("push_subscriptions")
}

// Per-user native device push tokens registered by the Capacitor app. One
// row per (user × device). FCM tokens for Android come directly from the
// Firebase SDK embedded via @capacitor/push-notifications. iOS tokens are
// either raw APNS device tokens (if the app ships without Firebase iOS SDK)
// or FCM tokens (if Firebase Messaging iOS SDK is added). The `platform`
// column lets the server sender route correctly. Rows auto-delete on 404/
// UNREGISTERED responses from the provider.
model DevicePushToken {
  id         String             @id @default(cuid())
  userId     String
  token      String             @unique
  platform   DevicePushPlatform
  appVersion String?
  deviceName String?
  lastSeenAt DateTime           @default(now())
  createdAt  DateTime           @default(now())
  user       User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("device_push_tokens")
}

enum DevicePushPlatform {
  IOS
  ANDROID
}

// Per-user notification preferences. Each type-specific toggle gates both
// in-app persistence and push send; the two global switches below scope the
// channel. quietHoursStart/End are 0-23 ints in the user's local timezone
// (from User.timezone) — push is suppressed during the window but the
// in-app Notification row is still created so the user sees it later.
model NotificationPreference {
  userId           String   @id
  inAppEnabled     Boolean  @default(true)
  pushEnabled      Boolean  @default(true)
  workoutAssigned  Boolean  @default(true)
  workoutUpdated   Boolean  @default(true)
  prLogged         Boolean  @default(true)
  messageReceived  Boolean  @default(true)
  programCompleted Boolean  @default(true)
  trainerFeedback  Boolean  @default(true)
  quietHoursStart  Int?
  quietHoursEnd    Int?
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_preferences")
}

model ContactSubmission {
  id              String        @id @default(cuid())
  name            String
  email           String
  phone           String?
  message         String
  age             String?
  fitnessLevel    String?
  fitnessGoals    String?
  currentActivity String?
  injuries        String?
  availability    String?
  status          ContactStatus @default(NEW)
  trainerId       String?
  trainer         User?         @relation("TrainerApplications", fields: [trainerId], references: [id], onDelete: SetNull)
  waitlist        Boolean       @default(false)
  kind            ContactSubmissionKind @default(APPLICATION)
  notifiedAt      DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([status])
  @@index([createdAt])
  @@index([trainerId, status])
  @@map("contact_submissions")
}

model Invitation {
  id         String           @id @default(cuid())
  email      String
  phone      String?
  code       String           @unique
  invitedBy  String
  // Role the redeemer will be granted when the code is accepted. Defaults to
  // CLIENT for backward compat (any existing Invitation row predating this
  // column reads as CLIENT). Admin issues TRAINER invites for hand-onboarded
  // coaches + foundation testers.
  role       String           @default("CLIENT")
  status     InvitationStatus @default(PENDING)
  expiresAt  DateTime
  acceptedAt DateTime?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  inviter    User             @relation("InvitationInviter", fields: [invitedBy], references: [id])

  @@unique([email, status])
  @@index([status])
  @@index([expiresAt])
  @@map("invitations")
}

model Appointment {
  id             String            @id @default(cuid())
  clientId       String
  trainerId      String
  title          String
  description    String?
  type           AppointmentType
  status         AppointmentStatus @default(PENDING)
  startTime      DateTime
  endTime        DateTime
  duration       Int
  location       String?
  notes          String?
  cancelReason   String?
  adminNotes     String?
  lastModifiedBy String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  client         User              @relation("ClientAppointments", fields: [clientId], references: [id])
  trainer        User              @relation("TrainerAppointments", fields: [trainerId], references: [id])

  @@index([clientId])
  @@index([trainerId])
  @@index([startTime])
  @@index([status])
  @@index([trainerId, startTime])
  @@map("appointments")
}

enum AppointmentType {
  TRAINING_SESSION
  CHECK_IN
  NUTRITION_CONSULTATION
  ASSESSMENT
  FOLLOW_UP
}

enum AppointmentStatus {
  PENDING
  APPROVED
