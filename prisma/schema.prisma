generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model User {
  id                     String              @id @default(cuid())
  name                   String?
  email                  String              @unique
  emailVerified          DateTime?
  password               String?
  passwordChangeRequired Boolean             @default(false)
  image                  String?
  role                   Role                @default(CLIENT)
  isActive               Boolean             @default(true)
  lastLogin              DateTime?
  loginCount             Int                 @default(0)
  adminNotes             String?
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt
  trainerId              String?
  accounts               Account[]
  clientAppointments     Appointment[]       @relation("ClientAppointments")
  trainerAppointments    Appointment[]       @relation("TrainerAppointments")
  clientProfile          ClientProfile?
  foodEntries            FoodEntry[]
  favoriteFoods          FavoriteFood[]
  sentInvitations        Invitation[]        @relation("InvitationInviter")
  createdMealPlans       MealPlan[]          @relation("TrainerMealPlans")
  mealPlans              MealPlan[]
  receivedMessages       Message[]           @relation("MessageReceiver")
  sentMessages           Message[]           @relation("MessageSender")
  notifications          Notification[]
  nutritionPlans         NutritionPlan[]
  progressEntries        ProgressEntry[]
  sessions               Session[]
  trainer                Trainer?
  assignedTrainer        User?               @relation("TrainerClients", fields: [trainerId], references: [id])
  clients                User[]              @relation("TrainerClients")
  workoutProgress        WorkoutProgress[]
  workoutSessions        WorkoutSession[]
  createdWorkouts        Workout[]
  orders                 Order[]
  createdPrograms        Program[]           @relation("ProgramCreator")
  clientAssignments      ProgramAssignment[] @relation("ClientAssignments")
  assignedPrograms       ProgramAssignment[] @relation("TrainerAssignments")
  coachNotesAsTrainer    CoachNote[]         @relation("CoachNotesTrainer")
  coachNotesAsClient     CoachNote[]         @relation("CoachNotesClient")
  subscription           Subscription?

  @@index([email])
  @@index([role])
  @@index([trainerId])
  @@index([isActive])
  @@index([lastLogin])
  @@index([createdAt])
  @@map("users")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model AdminLog {
  id           String   @id @default(cuid())
  adminEmail   String
  action       String
  targetUserId String?
  targetEmail  String?
  details      Json?
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())

  @@index([adminEmail])
  @@index([action])
  @@index([targetUserId])
  @@index([createdAt])
  @@map("admin_logs")
}

model LoginEvent {
  id        String   @id @default(cuid())
  email     String
  userId    String?
  success   Boolean
  ipAddress String?
  userAgent String?
  reason    String? // "invalid_password", "account_disabled", "success", etc.
  createdAt DateTime @default(now())

  @@index([email])
  @@index([userId])
  @@index([success])
  @@index([createdAt])
  @@map("login_events")
}

model ApiRequestLog {
  id        String   @id @default(cuid())
  userId    String?
  userEmail String?
  method    String
  path      String
  status    Int
  ipAddress String?
  duration  Int? // ms
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([path])
  @@index([createdAt])
  @@map("api_request_logs")
}

model Trainer {
  id              String   @id @default(cuid())
  userId          String   @unique
  bio             String?
  specializations Json?
  experience      Int      @default(0)
  certifications  Json?
  hourlyRate      Float?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("trainers")
}

model ClientProfile {
  id                String       @id @default(cuid())
  userId            String       @unique
  age               Int?
  height            Float?
  weight            Float?
  fitnessGoals      Json?
  fitnessLevel      FitnessLevel @default(BEGINNER)
  medicalConditions Json?
  preferences       Json?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  user              User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("client_profiles")
}

model Exercise {
  id                  String               @id @default(cuid())
  name                String
  description         String?
  instructions        Json?
  muscleGroups        Json?
  equipment           Json?
  difficulty          Difficulty           @default(BEGINNER)
  imageUrl            String?
  videoUrl            String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  workoutExercises    WorkoutExercise[]
  workoutProgress     WorkoutProgress[]
  programDayExercises ProgramDayExercise[]

  @@index([name])
  @@index([difficulty])
  @@map("exercises")
}

model Workout {
  id          String            @id @default(cuid())
  title       String
  description String?
  duration    Int
  difficulty  Difficulty        @default(BEGINNER)
  type        WorkoutType       @default(STRENGTH)
  createdBy   String
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  exercises   WorkoutExercise[]
  sessions    WorkoutSession[]
  creator     User              @relation(fields: [createdBy], references: [id])

  @@index([createdBy])
  @@index([difficulty])
  @@index([type])
  @@map("workouts")
}

model WorkoutExercise {
  id         String   @id @default(cuid())
  workoutId  String
  exerciseId String
  sets       Int
  reps       Int?
  duration   Int?
  weight     Float?
  restTime   Int?
  notes      String?
  order      Int
  exercise   Exercise @relation(fields: [exerciseId], references: [id])
  workout    Workout  @relation(fields: [workoutId], references: [id], onDelete: Cascade)

  @@unique([workoutId, exerciseId])
  @@map("workout_exercises")
}

model WorkoutSession {
  id               String             @id @default(cuid())
  workoutId        String
  userId           String
  startTime        DateTime
  endTime          DateTime?
  completed        Boolean            @default(false)
  notes            String?
  rating           Int?
  caloriesBurned   Int?
  createdAt        DateTime           @default(now())
  exerciseProgress ExerciseProgress[]
  workoutProgress  WorkoutProgress[]
  user             User               @relation(fields: [userId], references: [id])
  workout          Workout            @relation(fields: [workoutId], references: [id])

  @@unique([workoutId, userId])
  @@index([userId, startTime])
  @@index([workoutId])
  @@map("workout_sessions")
}

model ExerciseProgress {
  id            String         @id @default(cuid())
  sessionId     String
  exerciseId    String
  setsCompleted Int
  repsPerSet    Json?
  weightsUsed   Json?
  restTimes     Json?
  notes         String?
  session       WorkoutSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("exercise_progress")
}

model WorkoutProgress {
  id               String         @id @default(cuid())
  userId           String
  exerciseId       String
  workoutSessionId String
  weight           Float?
  sets             Int?
  reps             Int?
  notes            String?
  date             DateTime       @default(now())
  createdAt        DateTime       @default(now())
  exercise         Exercise       @relation(fields: [exerciseId], references: [id])
  user             User           @relation(fields: [userId], references: [id])
  workoutSession   WorkoutSession @relation(fields: [workoutSessionId], references: [id])

  @@index([userId, date])
  @@index([exerciseId])
  @@map("workout_progress")
}

model Food {
  id                 String      @id @default(cuid())
  name               String
  brand              String?
  caloriesPerServing Int
  protein            Float
  carbs              Float
  fat                Float
  fiber              Float?
  sugar              Float?
  sodium             Float?
  servingSize        String
  servingUnit        String
  createdAt          DateTime    @default(now())
  foodEntries        FoodEntry[]
  mealItems          MealItem[]

  @@index([name])
  @@map("foods")
}

model CommunityFood {
  id          String   @id @default(cuid())
  barcode     String?  @unique
  name        String
  brand       String?
  calories    Float
  protein     Float
  carbs       Float
  fat         Float
  fiber       Float?
  sugar       Float?
  servingSize Float
  servingUnit String
  category    String?
  verified    Boolean  @default(false)
  addedBy     String
  useCount    Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([barcode])
  @@index([name])
  @@index([brand])
  @@index([useCount])
  @@map("community_foods")
}

model FoodEntry {
  id        String   @id @default(cuid())
  userId    String
  foodName  String
  quantity  Float
  unit      String
  calories  Float
  protein   Float
  carbs     Float
  fat       Float
  mealType  MealType
  date      DateTime
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  foodId    String?
  food      Food?    @relation(fields: [foodId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId, date])
  @@index([date])
  @@index([mealType])
  @@map("food_entries")
}

model FavoriteFood {
  id          String   @id @default(cuid())
  userId      String
  foodName    String
  brand       String?
  calories    Float
  protein     Float
  carbs       Float
  fat         Float
  servingSize Float
  servingUnit String
  category    String?
  sourceId    String? // External ID (usda-xxx, off-xxx, local-xxx)
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, foodName, brand])
  @@index([userId])
  @@map("favorite_foods")
}

model Meal {
  id         String     @id @default(cuid())
  name       String
  type       MealType
  mealPlanId String
  items      MealItem[]
  mealPlan   MealPlan   @relation(fields: [mealPlanId], references: [id], onDelete: Cascade)

  @@map("meals")
}

model MealItem {
  id       String  @id @default(cuid())
  mealId   String
  foodId   String
  quantity Float
  notes    String?
  food     Food    @relation(fields: [foodId], references: [id])
  meal     Meal    @relation(fields: [mealId], references: [id], onDelete: Cascade)

  @@map("meal_items")
}

model MealPlan {
  id                 String   @id @default(cuid())
  name               String
  description        String?
  userId             String
  trainerId          String
  startDate          DateTime
  endDate            DateTime
  dailyCalorieTarget Int
  dailyProteinTarget Float
  dailyCarbTarget    Float
  dailyFatTarget     Float
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  trainer            User     @relation("TrainerMealPlans", fields: [trainerId], references: [id])
  user               User     @relation(fields: [userId], references: [id])
  meals              Meal[]

  @@index([userId])
  @@index([trainerId])
  @@map("meal_plans")
}

model NutritionPlan {
  id            String   @id @default(cuid())
  userId        String
  dailyCalories Float
  proteinGrams  Float
  carbsGrams    Float
  fatGrams      Float
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("nutrition_plans")
}

model ProgressEntry {
  id           String   @id @default(cuid())
  userId       String
  date         DateTime
  weight       Float?
  bodyFat      Float?
  muscleMass   Float?
  measurements Json?
  photos       Json?
  notes        String?
  mood         Int?
  energy       Int?
  sleep        Float?
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id])

  @@unique([userId, date])
  @@index([userId, date])
  @@map("progress_entries")
}

model Message {
  id         String      @id @default(cuid())
  senderId   String
  receiverId String
  content    String
  type       MessageType @default(TEXT)
  fileUrl    String?
  read       Boolean     @default(false)
  createdAt  DateTime    @default(now())
  receiver   User        @relation("MessageReceiver", fields: [receiverId], references: [id])
  sender     User        @relation("MessageSender", fields: [senderId], references: [id])

  @@index([senderId])
  @@index([receiverId])
  @@index([createdAt])
  @@map("messages")
}

model Notification {
  id            String           @id @default(cuid())
  userId        String
  title         String
  message       String
  type          NotificationType
  read          Boolean          @default(false)
  actionUrl     String?
  appointmentId String?
  createdAt     DateTime         @default(now())
  user          User             @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([read])
  @@map("notifications")
}

model ContactSubmission {
  id              String        @id @default(cuid())
  name            String
  email           String
  phone           String?
  message         String
  age             String?
  fitnessLevel    String?
  fitnessGoals    String?
  currentActivity String?
  injuries        String?
  availability    String?
  status          ContactStatus @default(NEW)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([status])
  @@index([createdAt])
  @@map("contact_submissions")
}

model Invitation {
  id         String           @id @default(cuid())
  email      String
  phone      String?
  code       String           @unique
  invitedBy  String
  status     InvitationStatus @default(PENDING)
  expiresAt  DateTime
  acceptedAt DateTime?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  inviter    User             @relation("InvitationInviter", fields: [invitedBy], references: [id])

  @@unique([email, status])
  @@index([status])
  @@index([expiresAt])
  @@map("invitations")
}

model Appointment {
  id             String            @id @default(cuid())
  clientId       String
  trainerId      String
  title          String
  description    String?
  type           AppointmentType
  status         AppointmentStatus @default(PENDING)
  startTime      DateTime
  endTime        DateTime
  duration       Int
  location       String?
  notes          String?
  cancelReason   String?
  adminNotes     String?
  lastModifiedBy String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  client         User              @relation("ClientAppointments", fields: [clientId], references: [id])
  trainer        User              @relation("TrainerAppointments", fields: [trainerId], references: [id])

  @@index([clientId])
  @@index([trainerId])
  @@index([startTime])
  @@index([status])
  @@index([trainerId, startTime])
  @@map("appointments")
}

enum AppointmentType {
  TRAINING_SESSION
  CHECK_IN
  NUTRITION_CONSULTATION
  ASSESSMENT
  FOLLOW_UP
}

enum AppointmentStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum Role {
  CLIENT
  TRAINER
  ADMIN
}

enum FitnessLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum Difficulty {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum WorkoutType {
  STRENGTH
  CARDIO
  FLEXIBILITY
  MIXED
}

enum MealType {
  BREAKFAST
  LUNCH
  DINNER
  SNACK
}

enum MessageType {
  TEXT
  IMAGE
  FILE
}

enum NotificationType {
  WORKOUT_ASSIGNED
  MEAL_PLAN_ASSIGNED
  MEAL_PLAN_ENDED
  MESSAGE_RECEIVED
  PROGRESS_REMINDER
  APPOINTMENT_CANCELLED
  APPOINTMENT_RESCHEDULED
  APPOINTMENT_READ
  GENERAL
}

enum ContactStatus {
  NEW
  IN_PROGRESS
  CONTACTED
  INVITED
  COMPLETED
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

// ─── ECOMMERCE MODELS ───

model ProductCategory {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  sortOrder   Int       @default(0)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  products    Product[]
}

model Product {
  id                String           @id @default(cuid())
  name              String
  slug              String           @unique
  shortDescription  String?
  description       String?
  price             Int // Price in cents (e.g. 2999 = $29.99)
  compareAtPrice    Int? // Original price for sale display (cents)
  sku               String?
  stock             Int              @default(0)
  lowStockThreshold Int              @default(5)
  trackInventory    Boolean          @default(true)
  isActive          Boolean          @default(true)
  isFeatured        Boolean          @default(false)
  featuredOrder     Int              @default(0)
  categoryId        String?
  category          ProductCategory? @relation(fields: [categoryId], references: [id])
  images            ProductImage[]
  orderItems        OrderItem[]
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@index([slug])
  @@index([isActive, isFeatured])
  @@index([categoryId])
}

model ProductImage {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  alt       String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  @@index([productId])
}

model Order {
  id                    String            @id @default(cuid())
  orderNumber           String            @unique
  customerEmail         String
  customerName          String?
  userId                String? // If logged-in user
  user                  User?             @relation(fields: [userId], references: [id])
  status                OrderStatus       @default(PENDING)
  paymentStatus         PaymentStatus     @default(UNPAID)
  fulfillmentStatus     FulfillmentStatus @default(UNFULFILLED)
  subtotal              Int // Cents
  tax                   Int               @default(0)
  total                 Int // Cents
  stripeSessionId       String?           @unique
  stripePaymentIntentId String?           @unique
  notes                 String?
  pickupDate            DateTime?
  pickupTime            String? // e.g. "10:00 AM - 11:00 AM"
  pickupName            String? // Name for pickup
  pickupPhone           String? // Phone for pickup contact
  items                 OrderItem[]
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  @@index([customerEmail])
  @@index([userId])
  @@index([stripeSessionId])
  @@index([orderNumber])
}

model OrderItem {
  id          String  @id @default(cuid())
  orderId     String
  order       Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String
  product     Product @relation(fields: [productId], references: [id])
  productName String // Snapshot at time of purchase
  price       Int // Price in cents at time of purchase
  quantity    Int
  total       Int // price * quantity

  @@index([orderId])
  @@index([productId])
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  READY_FOR_PICKUP
  PICKED_UP
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  UNPAID
  PAID
  PARTIALLY_REFUNDED
  REFUNDED
  FAILED
}

enum FulfillmentStatus {
  UNFULFILLED
  READY_FOR_PICKUP
  PICKED_UP
}

// ══════════════════════════════════════════════════════════════════
// V4 Phase 8 additions — Program builder, coach notes, feature flags,
// Stripe subscriptions. All additive; no existing model altered in
// a breaking way.
// ══════════════════════════════════════════════════════════════════

model Program {
  id          String              @id @default(cuid())
  name        String
  description String?
  goal        String?
  durationWks Int
  isTemplate  Boolean             @default(false)
  archived    Boolean             @default(false)
  createdById String
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  creator     User                @relation("ProgramCreator", fields: [createdById], references: [id])
  weeks       ProgramWeek[]
  assignments ProgramAssignment[]

  @@index([createdById])
  @@index([isTemplate])
  @@index([archived])
  @@map("programs")
}

model ProgramWeek {
  id         String       @id @default(cuid())
  programId  String
  weekNumber Int
  name       String?
  notes      String?
  program    Program      @relation(fields: [programId], references: [id], onDelete: Cascade)
  days       ProgramDay[]

  @@unique([programId, weekNumber])
  @@index([programId])
  @@map("program_weeks")
}

model ProgramDay {
  id            String               @id @default(cuid())
  programWeekId String
  dayOfWeek     DayOfWeek
  sessionType   String
  notes         String?
  order         Int                  @default(0)
  programWeek   ProgramWeek          @relation(fields: [programWeekId], references: [id], onDelete: Cascade)
  exercises     ProgramDayExercise[]

  @@index([programWeekId])
  @@map("program_days")
}

model ProgramDayExercise {
  id           String     @id @default(cuid())
  programDayId String
  exerciseId   String
  order        Int
  sets         Int
  repsScheme   String
  targetWeight String?
  restSeconds  Int?
  tempo        String?
  notes        String?
  programDay   ProgramDay @relation(fields: [programDayId], references: [id], onDelete: Cascade)
  exercise     Exercise   @relation(fields: [exerciseId], references: [id])

  @@index([programDayId])
  @@index([exerciseId])
  @@map("program_day_exercises")
}

model ProgramAssignment {
  id           String           @id @default(cuid())
  programId    String
  clientId     String
  assignedById String
  startDate    DateTime
  currentWeek  Int              @default(1)
  status       AssignmentStatus @default(ACTIVE)
  notes        String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  program      Program          @relation(fields: [programId], references: [id])
  client       User             @relation("ClientAssignments", fields: [clientId], references: [id])
  assigner     User             @relation("TrainerAssignments", fields: [assignedById], references: [id])

  @@index([clientId])
  @@index([assignedById])
  @@index([programId])
  @@index([status])
  @@map("program_assignments")
}

enum DayOfWeek {
  MON
  TUE
  WED
  THU
  FRI
  SAT
  SUN
}

enum AssignmentStatus {
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED
}

model CoachNote {
  id        String      @id @default(cuid())
  trainerId String
  clientId  String
  body      String
  context   NoteContext @default(GENERAL)
  contextId String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  trainer   User        @relation("CoachNotesTrainer", fields: [trainerId], references: [id])
  client    User        @relation("CoachNotesClient", fields: [clientId], references: [id])

  @@index([trainerId])
  @@index([clientId])
  @@index([createdAt])
  @@map("coach_notes")
}

enum NoteContext {
  GENERAL
  TRAINING
  NUTRITION
  PROGRESS
}

model FeatureFlag {
  key         String   @id
  enabled     Boolean  @default(false)
  description String?
  updatedAt   DateTime @updatedAt
  updatedBy   String?

  @@map("feature_flags")
}

model Subscription {
  id                   String    @id @default(cuid())
  userId               String    @unique
  stripeCustomerId     String?   @unique
  stripeSubscriptionId String?   @unique
  stripePriceId        String?
  plan                 String?
  status               String?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean   @default(false)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  user                 User      @relation(fields: [userId], references: [id])

  @@index([stripeCustomerId])
  @@index([status])
  @@map("subscriptions")
}
